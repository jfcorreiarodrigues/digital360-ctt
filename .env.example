# Supabase — obrigatório em produção e desenvolvimento local
SUPABASE_URL=https://your-project-id.supabase.co
# Chave pública (anon) — NÃO usar no servidor, apenas no frontend se necessário
SUPABASE_ANON_KEY=your_anon_key_here
# Chave de serviço (service_role) — usada pelo servidor para bypass do RLS
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# API Key interna — protege os endpoints do servidor
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET=your_api_secret_here

# Origins permitidos pelo CORS (separados por vírgula)
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# Apenas para desenvolvimento local (activa o app.listen())
LOCAL_SERVER=true

# Caminho para o Chrome/Chromium local — necessário para export PDF em dev
# macOS:  /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux:  /usr/bin/chromium-browser
CHROMIUM_PATH=/usr/bin/chromium-browser

# URL do pacote Chromium para Vercel/serverless (descarregado em runtime)
CHROMIUM_REMOTE_EXEC_PATH=https://github.com/Sparticuz/chromium/releases/download/v131.0.1/chromium-v131.0.1-pack.tar

# Frontend — variáveis expostas ao Vite (prefixo VITE_ obrigatório)
VITE_API_KEY=your_api_secret_here
